afw_reg2 = 2.
wl_afw2 = 44.
wl_afw3 = 44.

!-----------------------------------------------------------------------------------------------------------------------
! Time of containment spray system recoverage
!-----------------------------------------------------------------------------------------------------------------------
tcss = 15000.

!-----------------------------------------------------------------------------------------------------------------------
! PES in Cold and Hot Legs
!-----------------------------------------------------------------------------------------------------------------------
tpesp = 1500.
dtpesp = 2000.

! CesPyNew = "newton_initialization.py"
cesar_in = -1
