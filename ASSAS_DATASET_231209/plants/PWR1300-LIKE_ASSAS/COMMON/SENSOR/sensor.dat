!-----------------------------------------------------------------------------------------------------------------------
! DEBIT TOTAL SORTANT
!-----------------------------------------------------------------------------------------------------------------------
STRU SENSOR
   NAME 'Q_SORT_P'
   #begin INST
      Q_DRCV = BASE : 'SENSOR' 'Q_DRCV' : 'value'
      Q_HOL = 0.
      Q_COL = BASE : 'SENSOR' 'QL_BCOL' : 'value'
      Q_RTGVC = 0.
      Q_SEB = 0.
      nloop = BASE:'DESIGN' : 'RCS':'nloop'
      DO i 1 nloop
         Q_HOL   = Q_HOL   + BASE : 'SENSOR' (WORD('QL_BHOL'//CHAR(i))) : 'value'
         Q_RTGVC = Q_RTGVC + BASE : 'SENSOR' (WORD('QLRTGVC'//CHAR(i))) : 'value'
      ENDDO
      DO i 1 3
         Q_SEB = Q_SEB + BASE : 'SENSOR' (WORD('QL_SEB'//CHAR(i))) : 'value'
      ENDDO
      QSORT = Q_HOL + Q_COL + Q_RTGVC + Q_SEB - Q_DRCV
      QSORT
   #end
END
!-----------------------------------------------------------------------------------------------------------------------
! DEBIT FUITE PRIMAIRE
!-----------------------------------------------------------------------------------------------------------------------
 STRU SENSOR
    NAME 'Q_FUI_P'
    #begin INST
       QSORT = BASE : 'SENSOR' 'Q_SORT_P' : 'value'
       QFUI = QSORT
       QFUI
    #end
 END
