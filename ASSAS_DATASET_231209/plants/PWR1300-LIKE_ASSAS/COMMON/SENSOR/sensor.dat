!  VESSEL LEVEL SdD/HBC/BC/BBC/SdC/BdC
!-----------------------------------------------------------------------------------------------------------------------
STRU SENSOR NAME 'SdD'
   #begin INST
      GMPP = BASE:'SENSOR' 'GMPP' : 'value'
      IF (GMPP == 0.) SdD = 92.
      IF (GMPP > 0.) SdD = 88.
      SdD
   #end
END
!-----------------------------------------------------------------------------------------------------------------------
! VESSEL LEVEL  HBC (UP HOT LEG)
!-----------------------------------------------------------------------------------------------------------------------
STRU SENSOR NAME 'HBC'
   #begin INST
      GMPP = BASE:'SENSOR' 'GMPP' : 'value'
      IF (GMPP == 0.) HBC = 79.5
      IF (GMPP > 0.) HBC = 81.
      HBC
   #end
END
