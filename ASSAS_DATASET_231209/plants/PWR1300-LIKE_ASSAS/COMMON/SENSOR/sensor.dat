!===========================================================================
!  Volume d'eau dans les puisards
!===========================================================================
STRU SENSOR
   NAME 'VL_PUIS'
   #begin INST
      VL_PUIS = 0.
      zz = BASE :'CONTAINM':'ZONE' 'SUMP'
      IFTHEN (POINTER(zz) > 0)
         geom = zz : 'GEOM'
         IF (NUMBER('VLIQ',geom) <> 0) VL_PUIS = geom:'VLIQ':0
      ENDIF
      VL_PUIS
   #end
END
STRU SENSOR
   NAME 'WL_PUIS'
   #begin INST
      WL_PUIS = 0.
      zz = BASE :'CONTAINM':'ZONE' 'SUMP'
      IFTHEN (POINTER(zz) > 0)
         ther = zz : 'THER'
         IF (NUMBER('VLIQ',ther) <> 0) WL_PUIS = ther:'WLEV':0
      ENDIF
      WL_PUIS
   #end
END
STRU SENSOR
   NAME 'TL_PUIS'
   #begin INST
      TL_PUIS = 300.
      zz = BASE :'CONTAINM':'ZONE' 'SUMP'
      IFTHEN (POINTER(zz) > 0)
         ther = zz : 'THER'
         IF (NUMBER('VLIQ',geom) <> 0) TL_PUIS = ther:'TLIQ':0
      ENDIF
      TL_PUIS
   #end
END
