!-------------------------------------------------------------------------------!
!    Masse_zone_element.plot output file [kg]
! M_elem : masse de l'element dans la zone [kg] !
! AE_elem : masse de l'element dans la zone sous forme aérosol [kg] !
! G_elem : masse de l'element dans la zone sous forme gazeuse [kg] !
! DP_elem : masse de l'element dans la zone sous forme de dépôt aérosol [kg] !
! L_elem : masse de l'element dans la zone sous forme liquide [kg] !
! PW_elem : masse de l'element dans la zone sous forme de dépôt sur les peintures immergées [kg] !
!-------------------------------------------------------------------------------!
(zoneJDD=zonecont)
(i=0)
#do
(i<-i+1)
#if(i > NUMBER AUXZONE) #exit
(zoneJDD(0) <- AUXZONE:i)
#enddo

(i=0)
#do
(i<-i+1)
#if(i > NUMBER ENVNAME) #exit
(zoneJDD(0) <- ENVNAME:i)
#enddo

(i=0)
#do
(i<-i+1)
#if(i > NUMBER zoneJDD) #exit
(zone=zoneJDD:i)
STRU PLOT
   FILE ("./results/Masse_"//zone//"_element.plot")
   FREQ (freqplot)

   (j=0)
   #do
   (j<-j+1)
   #if(j > NUMBER ALLFP) #exit
   (ename=ALLFP[j])

   (cvarpath="M_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FP':elem
         M
      #end
   END

   (cvarpath="AE_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPSM_STA' z)<>0) M=z:'FPSM_STA':'AEROSOL':elem
         M
      #end
   END

   (cvarpath="G_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPSM_STA' z)<>0) M=z:'FPSM_STA':'GAS':elem
         M
      #end
   END

   (cvarpath="DP_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPSM_STA' z)<>0) M=z:'FPSM_STA':'DEPOAERO':elem
         M
      #end
   END

   (cvarpath="L_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPSM_STA' z)<>0) M=z:'FPSM_STA':'LIQUID':elem
         M
      #end
   END

   (cvarpath="PW_"//ename)
   STRU VARI
      NAME (cvarpath)
      CVAR (ename)
      ZONE (zone)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPSM_STA' z)<>0) M=z:'FPSM_STA':'PWET':elem
         M
      #end
   END

   #enddo

END
#enddo

!-------------------------------------------------------------------------------!
!    Masse_zone_chimie.plot output file [kg]
! AE_chimie : masse de l'espčce chimique dans la zone sous forme d'aérosol [kg] !
! G_chimie : masse de l'espčce chimique dans la zone sous forme gazeuse [kg] !
! CY_chimie : masse de l'espčce chimique dans la zone sous forme CDRY [kg] !
! CD_chimie : masse de l'espčce chimique dans la zone sous forme condensée [kg] !
! CY_chimie : masse de l'espčce chimique dans la zone sous forme CWET [kg] !
! DP_chimie : masse de l'espčce chimique dans la zone sous forme dépôt aérosol [kg] !
! L_chimie : masse d'elements dans la zone sous forme liquide [kg] !
! PY_chimie : masse de l'espčce chimique dans la zone sous forme de dépôt sur les peintures seches [kg] !
! PW_chimie : masse de l'espčce chimique dans la zone sous forme de dépôt sur les peintures immergées [kg] !
! SY_chimie : masse d'elements dans la zone sous forme SDRY [kg] !
! SB_chimie : masse d'elements dans la zone sous forme SORBED [kg] !
! SW_chimie : masse d'elements dans la zone sous forme SWET [kg] !
!-------------------------------------------------------------------------------!

(i=0)
