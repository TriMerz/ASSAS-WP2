!-------------------------------------------------------------------------------!
!    Masse_relache_comb_forme.plot output file
! M_AE_CORE : Masse aérosol relaché par le combustible  [kg]
! M_GR_CORE : Masse gaz rares relaché par le combustible  [kg]
! M_I_CORE  : Masse iode relaché par le combustible  [kg]
! M_AE_VESSEL : Masse aérosol retenue par la cuve  [kg]
! M_GR_VESSEL : Masse gaz rares retenue par la cuve  [kg]
! M_I_VESSEL  : Masse iode retenue par la cuve  [kg]
! M_IAE_VESSEL  : Masse iode aérosol retenue par la cuve  [kg]
! M_IG_VESSEL  : Masse iode gazeux retenue par la cuve  [kg]
! M_AE_PRIMARY : Masse aérosol retenue par le primaire  [kg]
! M_GR_PRIMARY : Masse gaz rares retenue par le primaire [kg]
! M_I_PRIMARY  : Masse iode retenue par le primaire  [kg]
! M_IAE_PRIMARY  : Masse iode aérosol retenue par le primaire [kg]
! M_IG_PRIMARY  : Masse iode gazeux retenue par le primaire  [kg]
! M_AE_FU5 : Masse aérosol retenue par le filtre U5  [kg]
! M_GR_FU5 : Masse gaz rares retenue par le filtre U5 [kg]
! M_I_FU5  : Masse iode retenue par le filtre U5  [kg]
! M_IAE_FU5  : Masse iode aérosol retenue par le filtre U5 [kg]
! M_IG_FU5 : Masse iode gazeux retenue par le filtre U5  [kg]
! M_AE_FTH : Masse aérosol retenue par le filtre inter-enceinte  [kg]
! M_GR_FTH : Masse gaz rares retenue par le filtre inter-enceinte [kg]
! M_I_FTH  : Masse iode retenue par le filtre inter-enceinte  [kg]
! M_IAE_FTH  : Masse iode aérosol retenue par le filtre inter-enceinte [kg]
! M_IG_FTH : Masse iode gazeux retenue par le filtre inter-enceinte  [kg]
! M_AE_FBK : Masse aérosol retenue par le filtre BK  [kg]
! M_GR_FBK : Masse gaz rares retenue par le filtre BK  [kg]
! M_I_FBK  : Masse iode retenue par le filtre BK   [kg]
! M_IAEFBK  : Masse iode aérosol retenue par le filtre BK  [kg]
! M_IG_FBK : Masse iode gazeux retenue par le filtre BK   [kg]
! M_AE_FBAS : Masse aérosol retenue par le filtre BAS  [kg]
! M_GR_FBAS : Masse gaz rares retenue par le filtre BAS [kg]
! M_I_FBAS  : Masse iode retenue par le filtre BAS  [kg]
! M_IAEFBAS  : Masse iode aérosol retenue par le filtre BAS [kg]
! M_IG_FBAS : Masse iode gazeux retenue par le filtre BAS  [kg]
!-------------------------------------------------------------------------------!
STRU PLOT
   FILE ("./results/Masse_retenue_forme.plot")
   FREQ (freqplot)

STRU VARI
 NAME M_AE_CORE
 #begin PATH
    massaero=0.
    conn_aero = BASE:'CONNECTI' 'CORE_UPP'
    DO i 1 NUMBER 'SOURCE' conn_aero
       source=conn_aero:'SOURCE' i
       IF(source:'TYPE' <> 'AEROSOL') NEXTCYCLE
       massaero=massaero+source:'MTOT'
    ENDDO
    massaero
#end
END

STRU VARI
   NAME M_GR_CORE
   #begin INST
      massgas=0.
      coreup = BASE:'CONNECTI' 'CORE_UPP'
      DO j 1 NUMBER('SOURCE' coreup)
         source=coreup:'SOURCE' j
         IFTHEN(NUMBER('SPEC' source)<>0)
            spec = source:'SPEC'
            IF(spec=='Kr' || spec=='Xe') massgas = massgas+source:'MTOT'
         ENDIF
      ENDDO
      massgas
   #end
END

STRU VARI
   NAME M_I_CORE
   #begin INST
      massI=0.
      coreup= BASE:'CONNECTI' 'CORE_UPP'
      DO j 1 NUMBER('SOURCE' coreup)
         source=coreup:'SOURCE' j
         IFTHEN(NUMBER('SPEC' source)<>0)
            spec = source:'SPEC'
            IF(spec=='I') massI = massI + source:'MTOT'
         ENDIF
      ENDDO
      massI
   #end
END

STRU VARI
   NAME M_AE_VESSEL
   #begin INST
      M = 0.
      vessel = BASE:'VESSEL'
      IF(NUMBER('FPDI' vessel)<>0) M = vessel:'FPDI':'FPMASS':'AEROSOL'
      M
   #end
END

STRU VARI
   NAME M_GR_VESSEL
   #begin INST
      M = 0.
      vessel = BASE:'VESSEL'
      IFTHEN(NUMBER('FPDI' vessel)<>0)
         M = vessel:'FPDI':'FP':'Kr'
         M = M+vessel:'FPDI':'FP':'Xe'
      ENDIF
      M
   #end
END

STRU VARI
   NAME M_I_VESSEL
   #begin INST
      M = 0.
      vessel = BASE:'VESSEL'
      IF(NUMBER('FPDI' vessel)<>0) M = vessel:'FPDI':'FP':'I'
      M
   #end
END

STRU VARI
   NAME M_IAE_VESSEL
