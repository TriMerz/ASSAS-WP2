!-------------------------------------------------------------------------------!
!    Masse_relachee_SEBIM.plot output file                                      !
!-------------------------------------------------------------------------------!
!        MSEBi_element : Masse relachee par element (FP) et par la SEBIM i [kg] !
!        M_FB_SEBi     : Masse relachee de FP par la SEBIM i               [kg] !
!        M_AE_SEBi     : Masse relachee de AEROSOL par la SEBIM i          [kg] !
!-------------------------------------------------------------------------------!
STRU PLOT
   FILE ("./results/Masse_relache_SEBIM.plot")
   FREQ (freqplot)

   (k=0)
   #do
   (k<-k+1)
   #if(k > NUMBER PRV) #exit
   (sebname=PRV[k])

   (i=0)
   #do
   (i<-i+1)
   #if(i > NUMBER ALLFP) #exit
   (ename=ALLFP[i])
   STRU VARI
      NAME ("MSEB"//sebname[8]//"_"//ename)
      CVAR (ename)
      SEBNAME (sebname)
      #begin INST
         M = 0.
         elem = (VARI:'CVAR')
         seb = (VARI: 'SEBNAME')
         sebim = BASE:'CONNECTI' seb
         DO j 1 NUMBER('SOURCE' sebim)
            source=sebim:'SOURCE' j
            IFTHEN(NUMBER('SPEC' source)<>0)
               spec = source :'SPEC'
               IF(spec==elem) M = source:'MTOT'
            ENDIF
         ENDDO
         M
      #end
   END
   #enddo

   STRU VARI
      NAME ("M_FP_SB"//sebname[8])
      SEBNAME (sebname)
      #begin INST
         mfp = 0.
         seb = (VARI: 'SEBNAME')
         sebim = BASE:'CONNECTI' seb
         DO j 1 NUMBER('SOURCE' sebim)
            source=sebim:'SOURCE' j
            IF(source:'TYPE' <> 'FP') NEXTCYCLE
            mfp = mfp + source:'MTOT'
         ENDDO
         mfp
      #end
   END

   STRU VARI
      NAME ("M_AE_SB"//sebname[8])
      SEBNAME (sebname)
      #begin INST
         maero = 0.
         seb = (VARI: 'SEBNAME')
         sebim = BASE:'CONNECTI' seb
         DO j 1 NUMBER('SOURCE' sebim)
            source=sebim:'SOURCE' j
            IF(source:'TYPE' <> 'AEROSOL') NEXTCYCLE
            maero = maero + source:'MTOT'
         ENDDO
         maero
      #end
   END

   #enddo

END


!-------------------------------------------------------------------------------!
!    Masses transferees de l'EI vers les batiments auxiliaires [kg]             !
!    Masses transferees des batiments auxiliaires vers l'environnement [kg]     !
!-------------------------------------------------------------------------------!

! EI vers ...

(i=0)
#do
(i<-i+1)
#if(i > NUMBER AUXBAT) #exit
(ename=AUXBAT[i])
STRU PLOT
   FILE ("./results/FPtransfer_EI-"//ename//".plot")
   FREQ (freqplot)

   (k=0)
   #do
   (k=k+1)
   #if (k> NUMBER ALLFP) #exit
   (name = ALLFP:k)
   STRU VARI
      NAME (name)
      CTO (ename)
      #begin PATH
         name = VARI : 'NAME'
         cto = VARI :'CTO'
         n = NUMBER('CONN',BASE:'CONTAINM')
         mpftot = 0.
         DO j 1 n
               conn = BASE:'CONTAINM':'CONN' j
               IFTHEN( conn:'TYPE' == 'FAN' )
                  IFTHEN( conn:'TO' == cto)
                     IFTHEN(NUMBER ( 'FPDI', conn ) <> 0)
                        IFTHEN(NUMBER( name, conn:'FPDI' ) <> 0)
                           mpftot = mpftot + conn:'FPDI':name[0]
                        ENDIF
                     ENDIF
                  ENDIF
               ENDIF
         ENDDO
         mpftot
      #end
!      CALL (varipath//"mfptrans.sp1")
   END
   #enddo
END
#enddo

! ... vers ENV

(i=0)
#do
(i<-i+1)
#if(i > NUMBER AUXBAT) #exit
(ename=AUXBAT[i])
STRU PLOT
   FILE ("./results/FPtransfer_"//ename//"_ENV.plot")
   FREQ (freqplot)

   (k=0)
   #do
   (k=k+1)
   #if (k> NUMBER ALLFP) #exit
   (name = ALLFP:k)
   STRU VARI
      NAME (name)
      CFROM (ename)
      #begin PATH
         name = VARI : 'NAME'
         cfrom = VARI :'CFROM'
         mpf = 0.
         DO j 1 NUMBER('CONN',BASE:'CONTAINM')
               conn = BASE:'CONTAINM':'CONN' j
               IF(conn:'TO' <> 'ENVIRON') NEXTCYCLE
               IFTHEN( conn:'FROM' == cfrom )
                  IFTHEN(NUMBER ( 'FPDI', conn ) <> 0)
                     IFTHEN(NUMBER( name, conn:'FPDI' ) <> 0)
                        mpf = mpf + conn:'FPDI':name[0]
                     ENDIF
                  ENDIF
               ENDIF
         ENDDO
         mpf
      #end
   END
   #enddo

END
#enddo
