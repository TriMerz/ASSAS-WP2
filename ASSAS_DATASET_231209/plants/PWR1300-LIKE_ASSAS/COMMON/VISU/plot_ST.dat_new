      vessel = BASE:'VESSEL'
      IF(NUMBER('FPSM_STA' vessel)<>0) M = vessel:'FPSM_STA':'AEROSOL':'I'
      M
   #end
END

STRU VARI
   NAME M_IG_VESSEL
