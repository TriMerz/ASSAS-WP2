!-------------------------------------------------------------------------------!
!    Thermo_zone.plot output file [kg]
! Tgas          : Température de la phase gaz                                           [K]    !
! Tparoi        : Température des parois                                                [K]    !
! Tliq          : Température de la phase liquide                                       [K]    !
! Vtot          : Volume totale de la zone                                              [m3]   !
! Vliq          : Volume de la phase liquide                                            [m3]   !
! Vgas          : Volume de la phase gazeuse                                            [m3]   !
! QDgas         : Débit de dose de la phase gaz                                         [Gy/s] !
! QDliq         : Débit de dose de la phase liquide                                     [Gy/s] !
! QDparoi       : Débit de dose sur les parois                                          [Gy/s] !
! XN2           : Fraction massique de N2                                               []     !
! pH            : pH dans la zone                                                       []     !
! Pgas          : Pression dans la zone                                                 [Pa]   !
! QCDparoi      : Débit de condensation de l'eau sur les murs                           [kg/s] !
! QEVAPparoi    : Débit d'évaporation de l'eau sur les murs                             [kg/s] !
! QCDliq        : Débit de condensation (>0) / d'évaporation (<0) de la phase liquide   [kg/s] !
!-------------------------------------------------------------------------------!

(i=0)
#do
(i<-i+1)
#if(i > NUMBER zoneJDD) #exit
(zone=zoneJDD:i)
STRU PLOT
   FILE ("./results/Thermo_"//zone//".plot")
   FREQ (freqplot)

   STRU VARI
      NAME Tgas
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('TFLU' therm)<>0) M=therm:'TFLU':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Tparoi
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('PHYSCHEM' z)<>0)
            phys=z:'PHYSCHEM'
            IF(NUMBER('TW_AVERA' phys)<>0) M=phys:'TW_AVERA'
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Tliq
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('TLIQ' therm)<>0) M=therm:'TLIQ':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Vtot
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('GEOM' z)<>0)
            geom=z:'GEOM'
            IF(NUMBER('VOLU' geom)<>0) M=geom:'VOLU'
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Vliq
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('GEOM' z)<>0)
            geom=z:'GEOM'
            IF(NUMBER('VLIQ' geom)<>0) M=geom:'VLIQ':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Vgas
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('GEOM' z)<>0)
            geom=z:'GEOM'
            IF(NUMBER('VOLU' geom)<>0 && NUMBER('VLIQ' geom)<>0) M=geom:'VOLU'-geom:'VLIQ':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QDgas
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('POWE' z)<>0)
            power=z:'POWE'
            IF(NUMBER('QDOSE_G' power)<>0) M=power:'QDOSE_G':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QDliq
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('POWE' z)<>0)
            power=z:'POWE'
            IF(NUMBER('QDOSE_L' power)<>0) M=power:'QDOSE_L':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QDparoi
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('POWE' z)<>0)
            power=z:'POWE'
            IF(NUMBER('QDOSE_W' power)<>0) M=power:'QDOSE_W':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME XN2
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('XN2' therm)<>0) M=therm:'XN2':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME pH
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('PH' therm)<>0) M=therm:'PH':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME Pgas
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('PRES' therm)<>0) M=therm:'PRES':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QCDparoi
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('QCOND' therm)<>0) M=therm:'QCOND':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QEVAparoi
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('QDRAIN' therm)<>0) M=therm:'QDRAIN':0
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME QCDliq
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('THER' z)<>0)
            therm=z:'THER'
            IF(NUMBER('DCON' therm)<>0) M=therm:'DCON':0
         ENDIF
         M
      #end
   END

END
#enddo

!-------------------------------------------------------------------------------!
!    GAS_I2_I2_total_diffusion.plot output file [moles]                         !
!    GAS_CH3I_CH3I_total_diffusion.plot output file [moles]                     !
!-------------------------------------------------------------------------------!
(spnames= SC1  'I2' 'CH3I')

(phname='GAS')

(ispe=0)
#do
(ispe<-ispe+1)
#if (ispe> NUMBER spnames) #exit
(spname=spnames : ispe)
(rname=spname//"_total_diffusion_mtr")
STRU PLOT
   FILE ("./results/"//phname//"_"//spname//"_"//rname//".plot")
   FREQ (freqplot)

   (i=0)
   #do
   (i=i+1)
   #if (i> NUMBER zoneJDD) #exit
   (zone=zoneJDD:i)
   STRU VARI
      NAME (zone)
      PHNAME (phname)
      SPNAME(spname)
      RNAME (rname)
      #begin PATH
         containm=BASE:CONTAINM
         zname=  VARI : NAME
         phname= VARI : PHNAME
         spname= VARI : SPNAME
         rname = VARI : RNAME
         moles=0.
         kreac=0
         sophopt =BASE : 'CALC_OPT'  1 : 'SOPHAEROS' 1
         phenomen= sophopt : 'PHENOMEN' 1
         kcont = phenomen : 'KCONT' 1
         nreac = NUMBER('REAC' kcont)
         DO ireac 1 nreac
            reac = kcont : REAC  ireac
            IF(reac==rname) kreac = ireac + 1
         ENDDO
         IFTHEN(kreac==0)
            PRINT "reaction " // rname //  " not found ; assumming reaction rate = 0.0"
            STOP 0.0
         ENDIF
         DO izon 1 NUMBER(  'ZONE' containm)
            path=containm : 'ZONE' izon
            IF(path : NAME == 'exte' ) NEXTCYCLE
            IF(path : NAME == 'environ' ) NEXTCYCLE
            IF(path : NAME == 'ban' ) NEXTCYCLE
            IF(path : NAME == 'bas' ) NEXTCYCLE
            IF(path : NAME == 'bk' ) NEXTCYCLE
            IF(path : NAME == 'eee1' ) NEXTCYCLE
            IF(path : NAME == 'eee2' ) NEXTCYCLE
            IFTHEN( path : NAME == zname )
               IFTHEN(NUMBER('PHYSCHEM' path)  > 0 )
                  physchem=path : 'PHYSCHEM' 1
                  kinetics=physchem : 'KINETICS' 1
                  IFTHEN(NUMBER phname kinetics==0)
                     PRINT "phase "//phname// " not found ; stopping execution"
                     PRINT rname //" "// phname //" "// spname// "in "//zname
                     STOPEXE
                  ENDIF
                  phase=kinetics : phname 1
                  IFTHEN(NUMBER spname phase==0)
                     PRINT "species  "//spname// " not found ; stopping execution"
                     PRINT rname //" "// phname //" "// spname// "in "//zname
                     STOPEXE
                  ENDIF
                  espece=phase : spname 1
                  moles = espece : kreac
               ENDIF
            ENDIF
         ENDDO
         (moles)
      #end
   END
   #enddo
END
#enddo

