!-------------------------------------------------------------------------------!
!    Masse_zone_forme.plot output file [kg]
! M_AE : masse d'elements dans la zone sous forme d'aérosol [kg] !
! M_G : masse d'elements dans la zone sous forme gazeuse [kg] !
! M_GR : masse de gaz rares dans la zone [kg]
! M_DP : masse d'elements dans la zone sous forme de dépôt aérosol [kg] !
! M_L : masse d'elements dans la zone sous forme liquide [kg] !
! M_PW : masse d'elements dans la zone sous forme de dépôt sur les peintures immergées [kg] !
!-------------------------------------------------------------------------------!

(i=0)
#do
(i<-i+1)
#if(i > NUMBER zoneJDD) #exit
(zone=zoneJDD:i)
STRU PLOT
   FILE ("./results/Masse_"//zone//"_forme.plot")
   FREQ (freqplot)

   STRU VARI
      NAME M_AE
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FPMASS':'AEROSOL'
         M
      #end
   END

   STRU VARI
      NAME M_G
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FPMASS':'GAS'
         M
      #end
   END

   STRU VARI
      NAME M_GR
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IFTHEN(NUMBER('FPDI' z)<>0)
            M=z:'FPDI':'FP':'Kr'
            M=M+z:'FPDI':'FP':'Xe'
         ENDIF
         M
      #end
   END

   STRU VARI
      NAME M_DP
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FPMASS':'DEPOAERO'
         M
      #end
   END

   STRU VARI
      NAME M_L
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FPMASS':'LIQUID'
         M
      #end
   END

   STRU VARI
      NAME M_PW
      ZONE (zone)
      #begin INST
         M = 0.
         area = (VARI:'ZONE')
         z = BASE:'CONTAINM':'ZONE' area
         IF(NUMBER('FPDI' z)<>0) M=z:'FPDI':'FPMASS':'PWET'
         M
      #end
   END

END
