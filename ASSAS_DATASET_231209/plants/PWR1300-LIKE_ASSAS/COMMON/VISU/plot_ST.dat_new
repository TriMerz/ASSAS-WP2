!-------------------------------------------------------------------------------!
!    activity_element.plot output file :                                        !
!-------------------------------------------------------------------------------!
!                                                                               !
!                                                                               !
!       * Activité totale relachee ŕ l'environnement    :  ATOT          [Bq]   !
!       * Activité PF ou MS relachee ŕ l'environnement  :  j             [Bq]   !
!-------------------------------------------------------------------------------!
STRU PLOT
   FILE ("./results/activity_element.plot")
   FREQ (freqplot)

   DATA "ATOT= BASE : FP_HEAT : ENVIRON : ACTISUM : 0"

   (i=0)
   #do
   (i<-i+1)
   #if(i > NUMBER ALLFP) #exit
   (ename=ALLFP[i])
   STRU VARI
      NAME (ename)
      #begin INST
         elem = (VARI:'NAME')
         enam = BASE:'PHYSICAL':'BANK':'ENAM'
         ind = 0
         DO j 1 NUMBER(enam)
            IF(enam:j == elem) ind = j+1
         ENDDO
         acti = 0.
         IF(ind <> 0) acti = BASE:'FP_HEAT':'ENVIRON':'ACTICUMU':ind
         acti
      #end
   END
   #enddo

END

!-------------------------------------------------------------------------------!
!    Masse_relache_comb_element.plot output file [kg]
!-------------------------------------------------------------------------------!
STRU PLOT
   FILE ("./results/Masse_relache_comb_element.plot")
   FREQ (freqplot)

   (i=0)
   #do
   (i<-i+1)
   #if(i > NUMBER ALLFP) #exit
   (ename=ALLFP[i])
   STRU VARI
      NAME (ename)
      #begin INST
         M = 0.
         elem = (VARI:'NAME')
         coreup = BASE:'CONNECTI' 'CORE_UPP'
         DO j 1 NUMBER('SOURCE' coreup)
            source=coreup:'SOURCE' j
            IFTHEN(NUMBER('SPEC' source)<>0)
               spec = source :'SPEC'
               IF(spec==elem) M = source:'MTOT'
            ENDIF
         ENDDO
         M
      #end
   END
   #enddo

END


