   STRU ZONE MODE 'NONEQUIL' NAME 'SUMP' ROOM 1 ! 1000m3 de ANNRBB affect�s � SUMP pour eviter remplissage
      STRU GEOM SELE (-3.0E+00+elevcpa) ASUM 1.0822E+03 VOLU 3.829300E+03 ELEV (-0.2+elevcpa) ! VOLU (2.9675E+03 + 1000 m3)
                CDRY 0.0 CWET 0.0 PDRY 0.0 PWET 14. SDRY 0.0 SWET 0.0
                LVNA 'SUM_LEV' SR1 LEVE 0. 0. 139.9 1. 140.9822 1.001 1222.1 2. 2304.3 3. 3386.5 4. TERM
      END
      STRU FPINIT NAME PWET SRG CONC 'R' 3.0E-2 TERM END
      STRU FPINIT NAME PDRY SRG CONC 'R' 3.0E-2 TERM END
      STRU INIT
         STRU COND COMP 'AIR' TYPE 'REST' PART 1 END
         STRU COND COMP 'TEMP' UNIT 'C' VALU 4.2E+01 PART 1 END
         STRU COND COMP 'SATUR' UNIT '%' VALU 0.5E+02 PART 1 END
         STRU COND COMP 'PRESS' UNIT 'PA' VALU 1.0E+05 PART 1 END
      END
      STRU THER
         PH 7.0
      END
   END
