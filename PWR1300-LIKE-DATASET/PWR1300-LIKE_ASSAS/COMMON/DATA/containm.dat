      STRU SPRA NAME 'SPRAY4' STYP 'EAS_SR'
         STRU PATH FRAC 0.072 SECT 109.0 SC1 PATH 'DOME' 'POOL' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP1' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP2' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP3' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP4' TERM END
         STRU PATH FRAC 0.014 SECT 21.5 SC1 PATH 'DOME' 'PRESSU' TERM END
         STRU PATH FRAC 0.044 SECT 68.0 SC1 PATH 'DOME' 'ANNRBH' TERM SIDE 1 WALL 'EDEGAPH' END
         STRU PATH FRAC 0.6318 SECT 960.9 SC1 PATH 'DOME' TERM END
