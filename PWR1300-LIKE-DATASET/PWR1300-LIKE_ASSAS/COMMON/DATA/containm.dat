   STRU CONN NAME 'F02P' TYPE 'PUMP_SYS'
      STRU PIPE FROM 'SUMP' TO 1 DZET 10. SECT 0.014 COMS "PUMP_LPR2" FELE (-2.9+elevcpa) END
      STRU PIPE FROM 1 TO 2 DZET 10. SECT 0.014 COMS "COOLER_RHR2" END
      STRU PIPE FROM 2 TO 3 DZET 10. SECT 0.014 COMS "VALVE_FS2" FELE (-2.9+elevcpa) END
