   !============================================================================================================================================================           
   ! EAS
   ! 252 buses d'aspersion par file d'aspersion
   ! 2 * 60 buses situees a 54.5 m
   ! 2 * 192 buses situees a 41.8 m
   ! debit en aspersion directe = 1000 m3/h
   ! debit en recurculation = 1200 m3/h
   ! surface de l'enceinte = 1676 m
   !============================================================================================================================================================
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   ! spray injection directe EAS voie A
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   STRU CONN NAME 'EASDIR1' TYPE 'PUMP_SYS'
      STRU PIPE FROM 'PTR' TO 1 DZET 10. SECT 0.014 COMS "PUMP_LPD1" FELE (0.01+elevcpa) END
      STRU PIPE FROM 1 TO 2 DZET 10. SECT 0.014 COMS "VALVE_FSD1" END
      STRU PIPE FROM 2 TO 'DOME' DZET 10. SECT 0.014 COMS "SPRAY_SPRAY1" TELE (50.+elevcpa) END
      STRU SPRA NAME 'SPRAY1' STYP 'EAS_SD'
         STRU PATH FRAC 0.072 SECT 109.0 SC1 PATH 'DOME' 'POOL' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP1' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP2' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP3' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP4' TERM END
         STRU PATH FRAC 0.014 SECT 21.5 SC1 PATH 'DOME' 'PRESSU' TERM END
         STRU PATH FRAC 0.044 SECT 68.0 SC1 PATH 'DOME' 'ANNRBH' TERM SIDE 1 WALL 'EDEGAPH' END
         STRU PATH FRAC 0.6318 SECT 960.9 SC1 PATH 'DOME' TERM END
         STRU PATH FRAC 0.0702 SECT 106.8 SC1 PATH 'DOME' TERM SIDE 1 WALL 'EDEDOME' END
      END
   END
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   ! spray injection directe EAS voie B
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   STRU CONN NAME 'EASDIR2' TYPE 'PUMP_SYS'
      STRU PIPE FROM 'PTR' TO 1 DZET 10. SECT 0.014 COMS "PUMP_LPD2" FELE (0.01+elevcpa) END
      STRU PIPE FROM 1 TO 2 DZET 10. SECT 0.014 COMS "VALVE_FSD2" END
      STRU PIPE FROM 2 TO 'DOME' DZET 10. SECT 0.014 COMS "SPRAY_SPRAY2" TELE (50.+elevcpa) END
      STRU SPRA NAME 'SPRAY2' STYP 'EAS_SD'
         STRU PATH FRAC 0.072 SECT 109.0 SC1 PATH 'DOME' 'POOL' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP1' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP2' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP3' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP4' TERM END
         STRU PATH FRAC 0.014 SECT 21.5 SC1 PATH 'DOME' 'PRESSU' TERM END
         STRU PATH FRAC 0.044 SECT 68.0 SC1 PATH 'DOME' 'ANNRBH' TERM SIDE 1 WALL 'EDEGAPH' END
         STRU PATH FRAC 0.6318 SECT 960.9 SC1 PATH 'DOME' TERM END
         STRU PATH FRAC 0.0702 SECT 106.8 SC1 PATH 'DOME' TERM SIDE 1 WALL 'EDEDOME' END
      END
   END
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   ! spray injection recirculation EAS voie A
   !------------------------------------------------------------------------------------------------------------------------------------------------------------
   STRU CONN NAME 'F01P' TYPE 'PUMP_SYS'
      STRU PIPE FROM 'SUMP' TO 1 DZET 10. SECT 0.014 COMS "PUMP_LPR1" FELE (-2.9+elevcpa) END
      STRU PIPE FROM 1 TO 2 DZET 10. SECT 0.014 COMS "COOLER_RHR1" END
      STRU PIPE FROM 2 TO 3 DZET 10. SECT 0.014 COMS "VALVE_FS1" FELE (-2.9+elevcpa) END
      STRU PIPE FROM 3 TO 'DOME' DZET 10. SECT 0.014 COMS "SPRAY_SPRAY3" TELE (50.+elevcpa) END
      STRU SPRA NAME 'SPRAY3' STYP 'EAS_SR'
         STRU PATH FRAC 0.072 SECT 109.0 SC1 PATH 'DOME' 'POOL' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP1' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP2' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP3' TERM END
         STRU PATH FRAC 0.042 SECT 64.1 SC1 PATH 'DOME' 'LOOP4' TERM END
         STRU PATH FRAC 0.014 SECT 21.5 SC1 PATH 'DOME' 'PRESSU' TERM END
         STRU PATH FRAC 0.044 SECT 68.0 SC1 PATH 'DOME' 'ANNRBH' TERM SIDE 1 WALL 'EDEGAPH' END
         STRU PATH FRAC 0.6318 SECT 960.9 SC1 PATH 'DOME' TERM END
         STRU PATH FRAC 0.0702 SECT 106.8 SC1 PATH 'DOME' TERM SIDE 1 WALL 'EDEDOME' END
      END
   END
